{
  "name": "@pluto/foundations",
  "version": "0.1.0",
  "description": "CSS foundations for Pluto Design System — reset, base styles, and token-driven utilities",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./reset.css": "./src/reset.css",
    "./base.css": "./src/base.css",
    "./a11y.css": "./src/a11y.css"
  },
  "files": [
    "dist",
    "src/*.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@pluto/tokens": "workspace:*"
  },
  "devDependencies": {
    "@pluto/tokens": "workspace:*",
    "@pluto/tsconfig": "workspace:*",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
